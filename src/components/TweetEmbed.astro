---
/**
 * TweetEmbed — Simulated tweet card matching the mockup design.
 * Displays a tweet with avatar initials, name, handle, body text,
 * and metadata (date, reposts, likes). No external Twitter/X embed.
 *
 * Props:
 *   name           — Display name (e.g., "Josh Hawley")
 *   handle         — Twitter handle (e.g., "@HawleyMO")
 *   body           — Full tweet text
 *   date           — Formatted date string (e.g., "3:47 PM · Jan 13, 2026")
 *   stats          — Engagement stats string (e.g., "12.4K Reposts · 38.1K Likes")
 *   screenshotUrl  — Optional screenshot image path (fallback if tweet deleted)
 */

interface Props {
  name: string;
  handle: string;
  body: string;
  date: string;
  stats?: string;
  screenshotUrl?: string;
}

const { name, handle, body, date, stats, screenshotUrl } = Astro.props;

/** Generate initials from the display name for the avatar circle */
const initials = name
  .split(' ')
  .map((word: string) => word[0])
  .join('')
  .toUpperCase();
---

<div class="mx-5 my-4 border border-neutral-200 rounded-xl p-4 bg-white">
  <!-- Tweet header: avatar + name + handle -->
  <div class="flex items-center gap-2.5 mb-3">
    <!-- Avatar circle with initials -->
    <div class="w-10 h-10 rounded-full bg-neutral-300 flex items-center justify-center
                font-bold text-xs text-neutral-700 shrink-0">
      {initials}
    </div>
    <div>
      <div class="font-bold text-sm">{name}</div>
      <div class="text-xs text-neutral-500">{handle}</div>
    </div>
  </div>

  <!-- Tweet body text -->
  <div class="text-[0.95rem] leading-relaxed text-neutral-900">
    {body}
  </div>

  <!-- Screenshot fallback (shown if tweet might be deleted) -->
  {screenshotUrl && (
    <img
      src={screenshotUrl}
      alt={`Screenshot of tweet by ${name}`}
      class="mt-3 rounded-lg border border-neutral-200 w-full"
      loading="lazy"
    />
  )}

  <!-- Metadata: date and engagement stats -->
  <div class="mt-3 pt-3 border-t border-neutral-100 text-xs text-neutral-500">
    {date}
    {stats && <span> &middot; {stats}</span>}
  </div>
</div>
