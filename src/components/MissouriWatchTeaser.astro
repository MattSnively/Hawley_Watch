---
/**
 * MissouriWatchTeaser — Sidebar widget teasing the Missouri Watch expansion.
 * Lists upcoming politicians that will be tracked. Links to Missouri Watch page.
 */

/** Politicians coming soon to Missouri Watch */
const upcoming = [
  { name: 'Sen. Eric Schmitt', title: 'U.S. Senator' },
  { name: 'Denny Hoskins', title: 'Secretary of State' },
  { name: 'Gov. Mike Kehoe', title: 'Governor' },
];
---

<div class="sidebar-card">
  <div class="sidebar-card-header red-bg">Missouri Watch</div>
  <div class="sidebar-card-body">
    <p class="text-sm text-neutral-700 mb-3">
      We're expanding accountability beyond Hawley. Coming soon:
    </p>

    <!-- Politician list -->
    <div class="text-sm leading-8">
      {upcoming.map((person) => (
        <div>
          <strong>{person.name}</strong> &mdash; {person.title}
        </div>
      ))}
    </div>

    <!-- Link to Missouri Watch page -->
    <div class="mt-3 text-center">
      <a href="/missouri-watch" class="read-more text-xs">Learn More &rarr;</a>
    </div>
  </div>
</div>
